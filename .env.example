# ClinicalTriage-Env — Environment Configuration
# Copy this to .env and fill in your values

# ── LLM Configuration ────────────────────────────────────────────────────────
# Your OpenAI-compatible API base URL (e.g. Hugging Face Inference API)
API_BASE_URL="https://router.huggingface.co/v1"

# The model identifier to use (e.g. meta-llama/Llama-3.1-8B-Instruct)
MODEL_NAME="meta-llama/Llama-3.1-8B-Instruct"

# Your Hugging Face API token (or OpenAI key)
HF_TOKEN="hf_your_huggingface_token_here"

# ── Environment Configuration ───────────────────────────────────────────────
# The local server URL (defaults to http://localhost:7860)
ENV_BASE_URL="http://localhost:7860"

# Replace HF_TOKEN above with your actual Hugging Face token
